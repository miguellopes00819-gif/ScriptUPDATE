local Camera = workspace.CurrentCamera

if CoreGui:FindFirstChild("DeltaMenuVip_V2") then CoreGui.DeltaMenuVip_V2:Destroy() end

getgenv().Aimbot = false; getgenv().ESPBox = false; getgenv().ESPDot = false; getgenv().ESPLine = false
getgenv().Velocidade = false; getgenv().Pulo = false

-- [UI Setup, Páginas e Botões idênticos aos anteriores...]
local ScreenGui = Instance.new("ScreenGui", CoreGui); ScreenGui.Name = "DeltaMenuVip_V2"
local OpenBtn = Instance.new("TextButton", ScreenGui); OpenBtn.Size = UDim2.new(0, 100, 0, 50); OpenBtn.Position = UDim2.new(0, 20, 0.5, -25); OpenBtn.Text = "MENU"; OpenBtn.TextColor3 = Color3.new(1,1,1); OpenBtn.BackgroundColor3 = Color3.fromRGB(30,30,30); OpenBtn.Font = Enum.Font.Code; OpenBtn.TextSize = 20
Instance.new("UICorner", OpenBtn); Instance.new("UIStroke", OpenBtn).Color = Color3.fromRGB(0, 150, 255)

local Main = Instance.new("Frame", ScreenGui); Main.Size = UDim2.new(0, 400, 0, 300); Main.Position = UDim2.new(0.5, -200, 0.5, -150); Main.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Main.Visible = false; Instance.new("UICorner", Main)
Instance.new("UIStroke", Main).Color = Color3.fromRGB(0, 150, 255); OpenBtn.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)

