local function criarAba(nome, target)
    local b = Instance.new("TextButton", Sidebar); b.Size = UDim2.new(0.85, 0, 0, 40); b.Text = nome; b.BackgroundColor3 = Color3.fromRGB(40, 40, 40); b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.Code; b.TextSize = 18; b.BorderSizePixel = 0; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() for _, p in pairs(Content:GetChildren()) do if p:IsA("ScrollingFrame") then p.Visible = false end end; target.Visible = true end)
end
criarAba("MENU", MenuPage); criarAba("VISUAL", VisualPage); criarAba("PLAYER", PlayerPage); criarAba("MISC", MiscPage)

local function btn(parent, nome, cfg)
    local b = Instance.new("TextButton", parent); b.Size = UDim2.new(0.9, 0, 0, 45); b.Text = nome; b.BackgroundColor3 = Color3.fromRGB(50,50,50); b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.Code; b.TextSize = 18; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() getgenv()[cfg] = not getgenv()[cfg]; b.BackgroundColor3 = getgenv()[cfg] and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(50,50,50) end)
end
btn(MenuPage, "Aimbot", "Aimbot"); btn(VisualPage, "ESP Box", "ESPBox"); btn(VisualPage, "ESP Ponto", "ESPDot"); btn(VisualPage, "ESP Linha", "ESPLine"); btn(PlayerPage, "Velocidade", "Velocidade"); btn(PlayerPage, "Pulo Alto", "Pulo")

-- Lógica Unificada (Aimbot + ESP + Movimento)
local espLines = {}

RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        if getgenv().Velocidade then char.HumanoidRootPart.CFrame += (char.Humanoid.MoveDirection * 0.3) end -- Nível 3
        char.Humanoid.JumpPower = getgenv().Pulo and 100 or 50
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
            local c = p.Character
            
            -- ESPs
            if getgenv().ESPBox then if not c:FindFirstChild("BoxESP") then local hl = Instance.new("Highlight", c); hl.Name = "BoxESP"; hl.FillColor = Color3.fromRGB(0, 150, 255) end elseif c:FindFirstChild("BoxESP") then c.BoxESP:Destroy() end
            if getgenv().ESPDot then if not c.Head:FindFirstChild("DotESP") then local bb = Instance.new("BillboardGui", c.Head); bb.Name = "DotESP"; bb.Size = UDim2.new(0, 10, 0, 10); bb.AlwaysOnTop = true; local f = Instance.new("Frame", bb); f.Size = UDim2.new(1,0,1,0); f.BackgroundColor3 = Color3.fromRGB(0,150,255) end elseif c.Head:FindFirstChild("DotESP") then c.Head:FindFirstChild("DotESP"):Destroy() end
            if getgenv().ESPLine then
                if not espLines[p.Name] then espLines[p.Name] = Drawing.new("Line") end
                local pos, vis = Camera:WorldToViewportPoint(c.HumanoidRootPart.Position)
                espLines[p.Name].Visible = vis
                if vis then espLines[p.Name].From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); espLines[p.Name].To = Vector2.new(pos.X, pos.Y); espLines[p.Name].Color = Color3.fromRGB(0, 150, 255) end
            elseif espLines[p.Name] then espLines[p.Name]:Remove(); espLines[p.Name] = nil end
        else
            if espLines[p.Name] then espLines[p.Name]:Remove(); espLines[p.Name] = nil end
        end
    end

    -- Aimbot com Raycast Anti-Wall
    if getgenv().Aimbot then
        local alvo = nil; local distMin = 500
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") and p.Character.Humanoid.Health > 0 then
                local headPos = p.Character.Head.Position
                local pos, vis = Camera:WorldToViewportPoint(headPos)
                local ray = Ray.new(Camera.CFrame.Position, (headPos - Camera.CFrame.Position).Unit * 500)
                local hit = workspace:FindPartOnRay(ray, LocalPlayer.Character)
                if vis and hit and hit:IsDescendantOf(p.Character) then
                    local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if d < distMin then alvo = p.Character.Head; distMin = d end
                end
            end
        end
        if alvo then Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, alvo.Position) end
    end
end)
